---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const currentPath = Astro.url.pathname;
const currentDocsVersion = 'v8.1';

const nav = [
  {
    title: 'v8 — Governance Substrate',
    items: [
      { href: '/docs', label: 'Introduction' },
      { href: '/docs/8.0', label: 'v8 Overview' },
      { href: '/docs/8.0/install', label: 'Install & init' },
      { href: '/docs/8.0/reasoning', label: 'Reasoning & FPF' },
      { href: '/docs/8.0/spec-onboarding', label: 'Spec onboarding' },
      { href: '/docs/8.0/check', label: 'Enforcement check' },
      { href: '/docs/8.0/harness-batch', label: 'Harness (alpha, Codex)' },
    ]
  },
  {
    title: 'Reference',
    items: [
      { href: '/docs/commands', label: 'All Commands' },
      { href: '/docs/faq', label: 'FAQ' },
      { href: '/docs/roadmap', label: 'Roadmap' },
    ]
  },
  {
    title: 'v7 — Spec-First',
    items: [
      { href: '/docs/7.0', label: 'v7 Overview' },
      { href: '/docs/7.0/install', label: 'Install & init' },
      { href: '/docs/7.0/spec-onboarding', label: 'Spec onboarding' },
      { href: '/docs/7.0/check', label: 'Enforcement check' },
      { href: '/docs/7.0/harness-batch', label: 'Batch harness (Beta)' },
    ]
  },
];

function isActive(href: string): boolean {
  const path = currentPath.replace(/\/$/, '');
  const target = href.replace(/\/$/, '');
  return path === target;
}
---

<Layout title={title} description={description}>
  <Header />

  <div class="flex-1 mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-8">

      <!-- Sidebar (desktop) -->
      <aside class="hidden lg:block w-56 shrink-0">
        <nav class="sticky top-24 space-y-6 text-sm">
          <div class="relative mb-4" id="version-wrapper">
            <button
              id="version-toggle"
              class="flex items-center gap-1.5 text-xs font-mono uppercase tracking-wider text-accent-green hover:text-text-primary transition-colors cursor-pointer"
            >
              {currentDocsVersion}
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div
              id="version-dropdown"
              class="hidden absolute top-6 left-0 z-50 bg-bg-secondary border border-border-subtle rounded shadow-lg py-1 min-w-[100px]"
            >
              <a href="/docs/8.0" class="block px-3 py-1.5 text-xs font-mono text-accent-green bg-bg-tertiary hover:text-text-primary transition-colors">v8.1 (latest)</a>
              <a href="/docs/7.0" class="block px-3 py-1.5 text-xs font-mono text-text-muted hover:text-text-primary hover:bg-bg-tertiary transition-colors">v7.0</a>
              <a href="/docs/5.3" class="block px-3 py-1.5 text-xs font-mono text-text-muted hover:text-text-primary hover:bg-bg-tertiary transition-colors">v5.3</a>
              <a href="/docs/5.0" class="block px-3 py-1.5 text-xs font-mono text-text-muted hover:text-text-primary hover:bg-bg-tertiary transition-colors">v5.0</a>
            </div>
          </div>
          {nav.map(section => (
            <div>
              <h4 class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2">
                {section.title}
              </h4>
              <ul class="space-y-1">
                {section.items.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'block py-1.5 px-3 rounded transition-colors',
                        isActive(item.href)
                          ? 'text-text-primary bg-bg-tertiary border-l-2 border-accent-green'
                          : 'text-text-secondary hover:text-text-primary hover:bg-bg-secondary'
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Mobile sidebar toggle -->
      <button
        id="docs-menu-toggle"
        class="lg:hidden fixed bottom-6 right-6 z-40 flex items-center gap-2 bg-bg-tertiary border border-border-hover text-text-primary px-4 py-3 rounded shadow-lg font-mono text-sm"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        Menu
      </button>

      <!-- Mobile sidebar overlay -->
      <div
        id="docs-menu-overlay"
        class="hidden lg:hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm"
      >
        <div class="absolute right-0 top-0 h-full w-72 bg-bg-primary border-l border-border-subtle overflow-y-auto p-6">
          <button id="docs-menu-close" class="absolute top-4 right-4 text-text-muted hover:text-text-primary p-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <nav class="space-y-6 text-sm mt-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-mono uppercase tracking-wider text-accent-green">{currentDocsVersion}</span>
            </div>
            {nav.map(section => (
              <div>
                <h4 class="font-mono text-xs uppercase tracking-wider text-text-muted mb-2">
                  {section.title}
                </h4>
                <ul class="space-y-1">
                  {section.items.map(item => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          'block py-2 px-3 rounded transition-colors',
                          isActive(item.href)
                            ? 'text-text-primary bg-bg-tertiary border-l-2 border-accent-green'
                            : 'text-text-secondary hover:text-text-primary hover:bg-bg-secondary'
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </nav>
        </div>
      </div>

      <!-- Content -->
      <main class="flex-1 min-w-0">
        <article class="prose-custom max-w-3xl">
          <slot />
        </article>
      </main>

    </div>
  </div>

  <Footer />
</Layout>

<style is:global>
  .prose-custom {
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
  .prose-custom h1 {
    font-size: 1.75rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #e8e8e8;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #1e1e1e;
  }
  .prose-custom h2 {
    font-size: 1.25rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #e8e8e8;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid #1e1e1e;
  }
  .prose-custom h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #e8e8e8;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-custom p {
    font-size: 1rem;
    color: #888888;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .prose-custom ul, .prose-custom ol {
    color: #888888;
    margin-bottom: 1.25rem;
    margin-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose-custom ul { list-style-type: disc; }
  .prose-custom ol { list-style-type: decimal; }
  .prose-custom li {
    line-height: 1.75;
  }
  .prose-custom code {
    color: #6b8afd;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    background: #111111;
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    word-break: keep-all;
    white-space: nowrap;
  }
  .prose-custom pre {
    background: #111111;
    border: 1px solid #1e1e1e;
    padding: 1.25rem;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    white-space: pre-wrap;
    word-wrap: break-word;
    max-width: 100%;
    overflow-x: auto;
  }
  .prose-custom pre code {
    color: #888888;
    background: transparent;
    padding: 0;
    white-space: pre-wrap;
    word-break: normal;
    word-break: normal;
  }
  .prose-custom a {
    color: #6b8afd;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  .prose-custom a:hover {
    color: #e8e8e8;
  }
  .prose-custom table {
    width: 100%;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    border: 1px solid #1e1e1e;
    border-radius: 4px;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
  }
  .prose-custom thead {
    background: #1a1a1a;
  }
  .prose-custom th {
    text-align: left;
    color: #555555;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #1e1e1e;
  }
  .prose-custom td {
    padding: 0.75rem 1rem;
    color: #888888;
    border-bottom: 1px solid rgba(30, 30, 30, 0.5);
  }
  .prose-custom tbody tr:hover {
    background: rgba(17, 17, 17, 0.5);
  }
  .prose-custom blockquote {
    border-left: 2px solid #46AB47;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #888888;
    font-style: italic;
  }
  .prose-custom .callout {
    border: 1px solid rgba(107, 138, 253, 0.2);
    background: rgba(107, 138, 253, 0.05);
    padding: 1.25rem;
    border-radius: 4px;
    margin: 1.5rem 0;
  }
  .prose-custom .callout-warn {
    border: 1px solid rgba(255, 204, 0, 0.2);
    background: rgba(255, 204, 0, 0.05);
    padding: 1.25rem;
    border-radius: 4px;
    margin: 1.5rem 0;
  }
  .prose-custom .callout p,
  .prose-custom .callout-warn p {
    margin-bottom: 0;
  }
  .prose-custom strong {
    color: #e8e8e8;
  }
  @media (min-width: 640px) {
    .prose-custom h1 { font-size: 2rem; }
    .prose-custom h2 { font-size: 1.375rem; }
    .prose-custom h3 { font-size: 1.25rem; }
  }
</style>

<script>
  // Mobile menu
  const toggle = document.getElementById('docs-menu-toggle');
  const overlay = document.getElementById('docs-menu-overlay');
  const close = document.getElementById('docs-menu-close');

  toggle?.addEventListener('click', () => overlay?.classList.remove('hidden'));
  close?.addEventListener('click', () => overlay?.classList.add('hidden'));
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.add('hidden');
  });

  // Version dropdown
  document.querySelectorAll('#version-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const dd = btn.parentElement?.querySelector('#version-dropdown');
      dd?.classList.toggle('hidden');
    });
  });
  document.addEventListener('click', (e) => {
    document.querySelectorAll('#version-dropdown').forEach(dd => {
      if (!dd.parentElement?.contains(e.target as Node)) {
        dd.classList.add('hidden');
      }
    });
  });

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      (btn as HTMLElement).style.color = '#46AB47';
      (btn as HTMLElement).style.borderColor = '#46AB47';
      setTimeout(() => {
        btn.textContent = orig;
        (btn as HTMLElement).style.color = '';
        (btn as HTMLElement).style.borderColor = '';
      }, 2000);
    });
  });
</script>
