<script>
  const tabButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[role="tab"]'),
  );
  const tabPanels = Array.from(
    document.querySelectorAll<HTMLElement>('[role="tabpanel"]'),
  );

  const activateTab = (activeButton: HTMLButtonElement) => {
    const activeTab = activeButton.dataset.tab;

    tabButtons.forEach((button) => {
      const isActive = button === activeButton;
      button.classList.toggle('tab-active', isActive);
      button.setAttribute('aria-selected', String(isActive));
      button.tabIndex = isActive ? 0 : -1;
    });

    tabPanels.forEach((panel) => {
      const isActive = panel.dataset.content === activeTab;
      panel.classList.toggle('tab-visible', isActive);
      panel.setAttribute('aria-hidden', String(!isActive));
    });
  };

  const tabIndexForKey = (key: string, currentIndex: number) => {
    const lastIndex = tabButtons.length - 1;
    const indexByKey: Record<string, number> = {
      ArrowLeft: currentIndex === 0 ? lastIndex : currentIndex - 1,
      ArrowRight: currentIndex === lastIndex ? 0 : currentIndex + 1,
      Home: 0,
      End: lastIndex,
    };
    return indexByKey[key];
  };

  tabButtons.forEach((button, currentIndex) => {
    button.addEventListener('click', () => activateTab(button));
    button.addEventListener('keydown', (event) => {
      const nextIndex = tabIndexForKey(event.key, currentIndex);
      if (nextIndex === undefined) return;

      event.preventDefault();
      const nextButton = tabButtons[nextIndex];
      activateTab(nextButton);
      nextButton.focus();
    });
  });

  const copyButton = document.querySelector<HTMLButtonElement>('#copy-btn');
  const installCommand = 'curl -fsSL https://haft.tools/install.sh | bash';
  const setCopyLabel = (label: string) => {
    if (!copyButton) return;
    copyButton.textContent = label;
  };

  copyButton?.addEventListener('click', async () => {
    if (!navigator.clipboard) {
      setCopyLabel('Copy manually');
      return;
    }

    try {
      await navigator.clipboard.writeText(installCommand);
    } catch {
      setCopyLabel('Copy manually');
      return;
    }

    setCopyLabel('Copied');
    window.setTimeout(() => setCopyLabel('Copy'), 2000);
  });

  interface ScrambleItem {
    from: string;
    to: string;
    start: number;
    end: number;
    char?: string;
  }

  class TextScramble {
    el: HTMLElement;
    chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789@#$%[]{}!?=+*^~';
    queue: ScrambleItem[] = [];
    frame = 0;
    frameRequest?: number;
    resolvePromise?: () => void;

    constructor(el: HTMLElement) {
      this.el = el;
    }

    setText(newText: string): Promise<void> {
      const oldText = this.el.innerText;
      const length = Math.max(oldText.length, newText.length);
      const indices = Array.from({ length }, (_, index) => index);

      this.queue = indices.map((index) => {
        const from = oldText[index] || '';
        const to = newText[index] || '';
        const start = Math.floor(Math.random() * 25);
        const end = to
          ? start + Math.floor(Math.random() * 30) + 12
          : start + Math.floor(Math.random() * 8) + 4;
        return { from, to, start, end };
      });

      if (this.frameRequest !== undefined) {
        cancelAnimationFrame(this.frameRequest);
      }
      this.frame = 0;

      return new Promise((resolve) => {
        this.resolvePromise = resolve;
        this.update();
      });
    }

    itemOutput(item: ScrambleItem) {
      if (this.frame >= item.end) return item.to;
      if (this.frame < item.start) return item.from;

      if (!item.char || Math.random() < 0.28) {
        item.char = this.chars[Math.floor(Math.random() * this.chars.length)];
      }
      return `<span class="glyph">${item.char}</span>`;
    }

    update() {
      const output = this.queue
        .map((item) => this.itemOutput(item))
        .join('');
      const completed = this.queue
        .filter((item) => this.frame >= item.end)
        .length;
      this.el.innerHTML = output;

      if (completed === this.queue.length) {
        const resolve = this.resolvePromise;
        this.resolvePromise = undefined;
        resolve?.();
        return;
      }

      this.frameRequest = requestAnimationFrame(() => {
        this.frame += 1;
        this.update();
      });
    }
  }

  const heroElement = document.querySelector<HTMLElement>('.scramble-hero');
  const textElement = document.querySelector<HTMLElement>('.scramble-text');

  if (heroElement && textElement) {
    const words: string[] = JSON.parse(heroElement.dataset.words || '[]');
    const scramble = new TextScramble(textElement);
    let counter = 0;

    const nextWord = () => {
      if (words.length === 0) return;
      counter = (counter + 1) % words.length;
      scramble
        .setText(words[counter])
        .then(() => window.setTimeout(nextWord, 2200));
    };

    window.setTimeout(nextWord, 2800);
  }
</script>
