---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
const rouletteWords = [
  'PROBLEM-OPS ENGINE',
  'EPISTEMIC DEBT CATCHER',
  'STRUCTURED REASONER',
  'PARITY ENFORCER',
  'EVIDENCE DECAY TRACKER',
  'WEAKEST LINK FINDER',
  'DECISION ARCHITECT',
];



---

<Layout title="Decision Engineering for AI Coding Tools">
  <Header />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-16 sm:py-24 lg:py-32">
      <div class="hero-glow"></div>
      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <!-- ASCII Logo - Desktop -->
<pre class="ascii-logo hidden md:block" aria-hidden="true"><span class="ascii-1"> ██████╗ ██╗   ██╗██╗███╗   ██╗████████╗</span>
<span class="ascii-2">██╔═══██╗██║   ██║██║████╗  ██║╚══██╔══╝</span>
<span class="ascii-3">██║   ██║██║   ██║██║██╔██╗ ██║   ██║   </span>
<span class="ascii-4">██║▄▄ ██║██║   ██║██║██║╚██╗██║   ██║   </span>
<span class="ascii-5">╚██████╔╝╚██████╔╝██║██║ ╚████║   ██║   </span>
<span class="ascii-6"> ╚══▀▀═╝  ╚═════╝ ╚═╝╚═╝  ╚═══╝   ╚═╝   </span></pre>
          <!-- Text Logo - Mobile -->
          <h1
            class="gradient-text-glow font-mono text-5xl font-bold md:hidden"
          >
            quint-code
          </h1>
          <span class="sr-only">quint-code</span>

          <!-- Scramble Roulette -->
          <div class="mt-6 w-full max-w-2xl" aria-label="ProblemOps for AI coding tools">
            <div class="scramble-hero" data-words={JSON.stringify(rouletteWords)}>
              <span class="scramble-text gradient-text">PROBLEM-OPS ENGINE</span>
            </div>
          </div>

          <p class="mt-4 text-lg text-text-muted">
            Make better decisions. Remember why you made them.
          </p>

          <!-- Install Command -->
          <div class="mt-10 w-full max-w-2xl">
            <div
              class="group relative overflow-hidden rounded-lg border border-border-subtle bg-bg-secondary"
            >
              <div class="flex items-center justify-center gap-2 sm:gap-4 px-3 sm:px-4 py-3 overflow-x-auto">
                <code class="text-xs sm:text-base text-text-secondary font-mono whitespace-nowrap">
                  <span class="text-accent-green">$</span>
                  curl -fsSL https://quint.codes/install.sh | bash
                </code>
                <button
                  id="copy-btn"
                  class="rounded px-3 py-2 min-h-[44px] min-w-[44px] text-xs text-text-muted transition-colors hover:bg-bg-tertiary hover:text-text-primary shrink-0"
                >
                  Copy
                </button>
              </div>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3 w-full max-w-md sm:max-w-none mx-auto">
            <Button href="/learn" class="w-full sm:w-auto">Get Started</Button>
            <Button
              href="https://github.com/m0n0x41d/quint-code"
              variant="secondary"
              external
              class="w-full sm:w-auto"
            >
              <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/>
              </svg>
              <span id="hero-stars" class="font-mono text-amber-400">--</span>
              <span class="mx-1 text-border-hover">|</span>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
              GitHub
            </Button>
          </div>

          <!-- Platform Badges -->
          <div class="platform-badges-container mt-10 grid grid-cols-2 gap-3 sm:flex sm:flex-wrap sm:justify-center sm:gap-x-6 sm:gap-y-2">
            <span class="platform-badge text-center">Claude Code</span>
            <span class="text-text-muted/30 hidden sm:inline">•</span>
            <span class="platform-badge text-center">Cursor</span>
            <span class="text-text-muted/30 hidden sm:inline">•</span>
            <span class="platform-badge text-center">Gemini CLI</span>
            <span class="text-text-muted/30 hidden sm:inline">•</span>
            <span class="platform-badge text-center">Codex CLI</span>
            <span class="text-text-muted/30 hidden sm:inline">•</span>
            <span class="platform-badge text-center">Codex App</span>
            <span class="text-text-muted/30 hidden sm:inline">•</span>
            <span class="platform-badge text-center">Air</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain Section -->
    <section class="border-t border-border-subtle py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold sm:text-3xl">The problem</h2>
        <div class="mt-8 max-w-2xl">
          <p class="text-lg leading-relaxed text-text-secondary">
            You and your AI make important decisions every day.
            You pick solutions confidently, intuitively, and even explain them clearly.
          </p>
          <p class="mt-4 text-lg text-text-secondary">
            <span class="text-text-primary font-semibold">But</span> there are many things silently going wrong:
          </p>
        </div>

        <div class="mt-12 space-y-4">
          <div class="border border-border-subtle bg-bg-secondary p-6 flex flex-col sm:flex-row sm:items-center gap-4">
            <h3 class="shrink-0 sm:w-64 font-mono text-sm font-semibold text-text-primary uppercase tracking-wider">The problem was never framed</h3>
            <p class="text-base text-text-secondary">
              You go straight to "use Kafka" before asking what's actually broken.
              Intuitive decisions feel fast and right — but intuition optimizes for familiarity, not for the problem at hand.
              Without a frame, you're solving something you never defined.
            </p>
          </div>
          <div class="border border-border-subtle bg-bg-secondary p-6 flex flex-col sm:flex-row sm:items-center gap-4">
            <h3 class="shrink-0 sm:w-64 font-mono text-sm font-semibold text-text-primary uppercase tracking-wider">Comparison doesn't happen</h3>
            <p class="text-base text-text-secondary">
              You and your AI settle on the first reasonable, intuitive option. No alternatives explored, no tradeoffs weighed.
              What looks like a "decision" is actually an approximation — the average, the familiar, the first thing that fits.
              Not the best. Just the first.
            </p>
          </div>
          <div class="border border-border-subtle bg-bg-secondary p-6 flex flex-col sm:flex-row sm:items-center gap-4">
            <h3 class="shrink-0 sm:w-64 font-mono text-sm font-semibold text-text-primary uppercase tracking-wider">"Why did we make that?"</h3>
            <p class="text-base text-text-secondary">
              Three months later, nobody remembers. The rationale disappeared into a chat thread you'll never find.
              Now you're reverse-engineering a decision from code comments and git blame.
            </p>
          </div>
          <div class="border border-border-subtle bg-bg-secondary p-6 flex flex-col sm:flex-row sm:items-center gap-4">
            <h3 class="shrink-0 sm:w-64 font-mono text-sm font-semibold text-text-primary uppercase tracking-wider">"Is this still the right call?"</h3>
            <p class="text-base text-text-secondary">
              Traffic tripled. Team doubled. Requirements shifted. But the architecture decision from 8 months ago is frozen in time.
              Nobody tracks when assumptions go stale.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works — Tabbed -->
    <section class="border-t border-border-subtle py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold sm:text-3xl">How it works</h2>

        <!-- Tabs -->
        <div class="mt-10 flex gap-0 border border-border-subtle w-fit">
          <button data-tab="auto" class="tab-btn tab-active px-5 py-3 font-mono text-sm uppercase tracking-wider transition-colors">/q-reason</button>
          <button data-tab="full" class="tab-btn px-5 py-3 font-mono text-sm uppercase tracking-wider border-l border-border-subtle transition-colors">Full cycle</button>
          <button data-tab="tactical" class="tab-btn px-5 py-3 font-mono text-sm uppercase tracking-wider border-l border-border-subtle transition-colors">Quick cycle</button>
          <button data-tab="note" class="tab-btn px-5 py-3 font-mono text-sm uppercase tracking-wider border-l border-border-subtle transition-colors">Micro-note</button>
        </div>

        <!-- Tab content — grid overlay keeps tallest height -->
        <div class="mt-0 border border-t-0 border-border-subtle bg-bg-secondary p-8 sm:p-10 grid [&>*]:col-start-1 [&>*]:row-start-1">

          <!-- /q-reason -->
          <div data-content="auto" class="tab-content tab-visible">
            <div class="max-w-3xl">
              <p class="text-text-primary font-semibold text-lg">One command. The agent reasons for you.</p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                Type <code class="text-accent-blue">/q-reason</code> and describe your problem.
                The agent follows a structured operating system of thought: frames the problem before solving it,
                generates genuinely distinct alternatives, compares them fairly on declared dimensions,
                and records the decision with full rationale, rollback plan, and expiry date.
              </p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                The agent auto-selects the right depth — tactical for quick reversible choices,
                standard for architectural decisions, deep for irreversible cross-team calls.
                You stay in the loop for every choice that matters.
              </p>
              <div class="mt-6 font-mono text-sm text-text-muted">
                <span class="text-accent-green">$</span> /q-reason "How should we handle cross-service transaction failures?"
              </div>
            </div>
          </div>

          <!-- Full cycle -->
          <div data-content="full" class="tab-content">
            <div class="max-w-3xl">
              <p class="text-text-primary font-semibold text-lg">Full control. Five steps, each a slash command.</p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                When you want to drive each phase manually — define dimensions before seeing options,
                enforce parity across variants, attach evidence with congruence levels.
              </p>
              <div class="mt-8 space-y-4">
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">1</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-frame</code>
                  <span class="text-base text-text-secondary">Define signal, constraints, optimization targets, acceptance criteria</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">2</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-char</code>
                  <span class="text-base text-text-secondary">Set comparison dimensions with roles — constraint, target, observation</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">3</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-explore</code>
                  <span class="text-base text-text-secondary">Generate genuinely distinct alternatives with weakest link per variant</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">4</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-compare</code>
                  <span class="text-base text-text-secondary">Fair comparison — same inputs, same scope, parity enforced</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">5</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-decide</code>
                  <span class="text-base text-text-secondary">Decision contract — invariants, rollback plan, refresh triggers, expiry</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick cycle -->
          <div data-content="tactical" class="tab-content">
            <div class="max-w-3xl">
              <p class="text-text-primary font-semibold text-lg">Reversible decision? Three steps.</p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                For choices with blast radius under 2 weeks — library picks, API design, caching strategy.
                Skip characterization and formal comparison. Frame, explore, decide.
              </p>
              <div class="mt-8 space-y-4">
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">1</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-frame</code>
                  <span class="text-base text-text-secondary">What's broken, what constraints, what does solved look like</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">2</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-explore</code>
                  <span class="text-base text-text-secondary">2-3 alternatives with tradeoffs</span>
                </div>
                <div class="flex items-start gap-4">
                  <span class="shrink-0 w-6 text-right font-mono text-sm text-text-muted">3</span>
                  <code class="shrink-0 w-28 text-accent-blue text-base">/q-decide</code>
                  <span class="text-base text-text-secondary">Pick one, record why, set expiry</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Micro-note -->
          <div data-content="note" class="tab-content">
            <div class="max-w-3xl">
              <p class="text-text-primary font-semibold text-lg">Capture what matters before it's forgotten.</p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                You discover the auth token has a hard 4KB limit that breaks with more than 12 roles.
                You realize the retry logic silently swallows timeout errors.
                You pick JSON over Protobuf because the client SDK doesn't support binary yet.
                These things never make it into docs — but they shape every decision downstream.
              </p>
              <p class="mt-4 text-base text-text-secondary leading-relaxed">
                You don't need to call <code class="text-accent-blue">/q-note</code> yourself — the agent
                captures micro-decisions automatically when it notices them in conversation.
                You said "let's go with gRPC" — it's recorded with rationale before you move on.
                No rationale — no record. Conflicts with active decisions are flagged.
                Auto-expires in 90 days so your knowledge base doesn't rot.
              </p>
              <div class="mt-6 font-mono text-sm text-text-muted">
                <span class="text-accent-green">$</span> /q-note "Auth token hard limit 4KB — breaks at 12+ roles, must split claims before RBAC expansion"
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- FPF Foundation -->
    <section class="border-t border-border-subtle py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div>
          <h2 class="text-2xl font-bold text-text-primary sm:text-3xl">
            Built on First Principles Framework
          </h2>
          <p class="mt-6 text-base text-text-secondary leading-relaxed">
            quint-code is built on top of
            <a
              href="https://github.com/ailev/FPF"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-primary underline decoration-accent-orange/50 underline-offset-4 hover:decoration-accent-orange transition-colors"
            >First Principles Framework</a>
            by
            <a
              href="https://www.linkedin.com/in/ailev/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-primary underline decoration-accent-orange/50 underline-offset-4 hover:decoration-accent-orange transition-colors"
            >Anatoly Levenchuk</a>
            — a rigorous, transdisciplinary architecture for thinking.
          </p>
          <a
            href="https://github.com/ailev/FPF"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex items-center gap-2 rounded-md border border-border-subtle px-5 py-3 text-sm font-semibold text-text-primary transition-all hover:border-accent-orange/50 hover:bg-bg-secondary"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            Read the FPF specification
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-t border-border-subtle py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold sm:text-3xl">Frequently asked questions</h2>

        <div class="mt-10 border border-border-subtle divide-y divide-border-subtle">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              Why do I need quint-code when there are SDD frameworks?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              SDD frameworks give you a structure for writing specs. quint-code gives your AI agent
              an operating system for thinking — problem framing, fair comparison, evidence tracking,
              and decision lifecycle management. It's not a document format. It's a reasoning process
              that produces artifacts with computed trust scores, expiry dates, and rollback plans.
              You can use both — SDD for specs, quint-code for the decisions behind them.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              How is this different from ADRs?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              ADRs are static markdown files you write after deciding. quint-code decisions are live artifacts —
              they have computed trust scores (R_eff) that degrade as evidence ages, expiry dates that trigger
              reviews, rollback plans with conditions, and they're searchable via full-text search.
              An ADR tells you what was decided. A quint-code decision tells you whether you should still trust it.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              Can I use it on an existing project?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              Yes. Run <code class="text-accent-blue">quint-code init</code> and then <code class="text-accent-blue">/q-onboard</code> —
              the agent will scan your codebase and surface existing architectural patterns worth documenting.
              You don't need to retroactively document everything. Start with your next decision.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              What happens when I switch between AI coding tools?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              quint-code stores everything in a local SQLite database with git-tracked markdown projections.
              The MCP server works with Claude Code, Cursor, Gemini CLI, Codex CLI, Codex App, and Air.
              Switch tools, your decisions stay. The knowledge is in your repo, not in a chat thread.
              Just make sure you initialized quint-code for the correct tool — default is Claude Code.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              Isn't this overkill for small projects?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              Use <code class="text-accent-blue">/q-note</code> for micro-decisions and <code class="text-accent-blue">/q-reason</code>
              which auto-selects tactical mode for small choices. The overhead is one command.
              The value is remembering why you chose X in 3 months when everything breaks.
              Small projects become big projects. Decisions made early matter the most.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              Does it work for teams or solo only?
              <span class="shrink-0 ml-4 text-text-muted group-open:rotate-180 transition-transform">&#8593;</span>
            </summary>
            <div class="px-6 pb-6 text-base text-text-secondary leading-relaxed">
              Currently solo-focused. The <code class="text-accent-blue">.quint/</code> directory is git-tracked,
              so teammates can read your decisions. But there's no collaborative editing, review workflows,
              or merge conflict resolution for the SQLite database yet. That's on the roadmap.
            </div>
          </details>

          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-mono text-sm uppercase tracking-wide text-text-primary hover:bg-bg-secondary transition-colors">
              Is quint-code good for vibe coding?
