<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Jersey+10&display=swap');

  .scramble-hero {
    font-family: 'Jersey 10', cursive;
    font-weight: 400;
    filter: drop-shadow(0 0 0.5px rgba(255, 135, 0, 0.6)) drop-shadow(0 0 1px rgba(255, 68, 68, 0.3));
    font-size: 1.5rem;
    line-height: 1.4;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-font-smoothing: none;
    -moz-osx-font-smoothing: grayscale;
    image-rendering: pixelated;
    letter-spacing: 0.05em;
  }
  @media (min-width: 640px) {
    .scramble-hero {
      font-size: 2.5rem;
      min-height: 3.5rem;
    }
  }
  @media (min-width: 1024px) {
    .scramble-hero {
      font-size: 3.25rem;
      min-height: 4.5rem;
    }
  }

  .scramble-text {
    display: inline-block;
    white-space: nowrap;
  }

  /* Unresolved glyphs — dim ember glow */
  .scramble-text .glyph {
    color: rgba(255, 135, 0, 0.3);
    display: inline-block;
  }

  /* Tab panels — all stacked in same grid cell */
  .tab-content {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }
  .tab-content.tab-visible {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  /* Tab buttons */
  .tab-btn {
    color: #555;
    background: transparent;
  }
  .tab-btn:hover {
    color: #e8e8e8;
    background: #1a1a1a;
  }
  .tab-btn.tab-active {
    color: #e8e8e8;
    background: #111111;
  }
</style>

<script>
  // Tabs — CSS grid overlay, all panels stacked, visibility toggles
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('tab-active'));
      btn.classList.add('tab-active');
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('tab-visible'));
      document.querySelector(`[data-content="${tab}"]`)?.classList.add('tab-visible');
    });
  });

  // Copy install command
  const copyBtn = document.getElementById('copy-btn');
  const installCmd = 'curl -fsSL https://quint.codes/install.sh | bash';
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(installCmd);
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });

  // Text scramble effect — each character resolves independently
  class TextScramble {
    el: HTMLElement;
    chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789@#$%&<>[]{}!?=+*^~アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン漢字決問題解析';
    queue: { from: string; to: string; start: number; end: number; char?: string }[] = [];
    frame = 0;
    frameRequest = 0;
    resolvePromise: (() => void) | null = null;

    constructor(el: HTMLElement) {
      this.el = el;
    }

    setText(newText: string): Promise<void> {
      const oldText = this.el.innerText;
      const length = Math.max(oldText.length, newText.length);
      this.queue = [];

      for (let i = 0; i < length; i++) {
        const from = oldText[i] || '';
        const to = newText[i] || '';
        // Each char gets a random start delay and resolve time
        // Characters that are disappearing (to='') resolve faster
        const start = Math.floor(Math.random() * 25);
        const end = to
          ? start + Math.floor(Math.random() * 30) + 12
          : start + Math.floor(Math.random() * 8) + 4;
        this.queue.push({ from, to, start, end });
      }

      cancelAnimationFrame(this.frameRequest);
      this.frame = 0;

      return new Promise((resolve) => {
        this.resolvePromise = resolve;
        this.update();
      });
    }

    update() {
      let output = '';
      let complete = 0;

      for (let i = 0; i < this.queue.length; i++) {
        const item = this.queue[i];
        const { from, to, start, end } = item;

        if (this.frame >= end) {
          // Resolved — show final character
          complete++;
          output += to;
        } else if (this.frame >= start) {
          // Scrambling — show random glyph
          if (!item.char || Math.random() < 0.28) {
            item.char = this.chars[Math.floor(Math.random() * this.chars.length)];
          }
          output += `<span class="glyph">${item.char}</span>`;
        } else {
          // Not started yet — show old character
          output += from;
        }
      }

      this.el.innerHTML = output;

      if (complete === this.queue.length) {
        this.resolvePromise?.();
        return;
      }

      this.frameRequest = requestAnimationFrame(() => {
        this.frame++;
        this.update();
      });
    }
  }

  // Initialize scramble roulette
  const heroEl = document.querySelector('.scramble-hero') as HTMLElement;
  const textEl = document.querySelector('.scramble-text') as HTMLElement;

  if (heroEl && textEl) {
    const words: string[] = JSON.parse(heroEl.dataset.words || '[]');
    if (words.length > 0) {
      const fx = new TextScramble(textEl);
      let counter = 0;

      const next = () => {
        counter = (counter + 1) % words.length;
        fx.setText(words[counter]).then(() => {
          setTimeout(next, 2200);
        });
      };

      // First word is already displayed — wait, then start cycling
      setTimeout(next, 2800);
    }
  }
</script>
